# ============================================================
# Neilos Partner Portal — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Application
APP_NAME="Neilos Partner Portal"
APP_URL="http://localhost/Neilos"
APP_ENV=production
APP_DEBUG=false

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=neilos_portal
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Session
SESSION_LIFETIME=28800
SESSION_SECURE=true
SESSION_SAMESITE=Strict

# Email (SMTP)
SMTP_HOST=smtp.neilosnetwork.co.tz
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@neilosnetwork.co.tz
SMTP_FROM_NAME="Neilos Partner Portal"

# File Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx,xlsx,csv

# Currency
USD_TZS_RATE=2500

# SLA Defaults
SLA_CRITICAL_HOURS=4
SLA_HIGH_HOURS=8
SLA_MEDIUM_HOURS=24
SLA_LOW_HOURS=72
